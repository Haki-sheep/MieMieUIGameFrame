# ================= 核心缓存目录 =================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# ================= 性能数据（可能很大且含敏感信息） =================
/[Mm]emoryCaptures/
/[Rr]ecordings/

# ================= 资源元数据（仅在对应资源也被忽略时才忽略） =================
!/[Aa]ssets/**/*.meta

# ================= Asset Store 工具（可选） =================
# /[Aa]ssets/AssetStoreTools*

# ================= JetBrains Rider 自动生成的插件 =================
/[Aa]ssets/Plugins/Editor/JetBrains*

# ================= IDE 缓存目录 =================
.vs/
.vscode/
.idea/

# ================= Gradle 缓存（Android） =================
.gradle/

# ================= 自动生成的解决方案和项目文件 =================
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ================= Unity 生成的元数据文件 =================
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ================= Unity 崩溃报告文件 =================
sysinfo.txt

# ================= 构建产物 =================
*.apk
*.aab
*.unitypackage
*.app

# ================= Crashlytics 生成的文件 =================
crashlytics-build.properties

# ================= Addressables 打包文件 =================
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
/ServerData/

# ================= Visual Scripting 自动生成的文件 =================
/[Aa]ssets/Unity.VisualScripting.Generated/